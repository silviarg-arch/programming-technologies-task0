<Window x:Class="ProgrammingTechnologiesTask2.Presentation.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Management System"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <DataTemplate x:Key="BookDetailTemplate">
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Selected Book Details"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="ID: " FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding BookId}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Title: " FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding Title}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Author: " FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding Author}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Year: " FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding PublicationYear}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="Status: " FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding AvailabilityText}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EventTemplate">
            <StackPanel Orientation="Horizontal" Margin="2">
                <TextBlock Text="{Binding EventDate}" Width="140"/>
                <TextBlock Text="{Binding EventType}" Width="120"/>
                <TextBlock Text="Book: " />
                <TextBlock Text="{Binding BookId}" Width="50"/>
                <TextBlock Text="Reader: " />
                <TextBlock Text="{Binding ReaderId}" Width="50"/>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Library Management System"
                       FontSize="24"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <TextBox Width="220"
                         Margin="5"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Search"
                        Width="90"
                        Margin="5"
                        Command="{Binding SearchCommand}"/>

                <Button Content="Load All"
                        Width="90"
                        Margin="5"
                        Command="{Binding LoadDataCommand}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- MASTER VIEW -->
            <GroupBox Header="Books - Master View"
                      Grid.Column="0"
                      Margin="0,0,10,0">

                <DataGrid ItemsSource="{Binding Books}"
                          SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding BookId}"
                                            Width="60"/>

                        <DataGridTextColumn Header="Title"
                                            Binding="{Binding Title}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Author"
                                            Binding="{Binding Author}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Year"
                                            Binding="{Binding PublicationYear}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding AvailabilityText}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- DETAIL VIEW -->
            <GroupBox Header="Detail View"
                      Grid.Column="1">

                <ScrollViewer>
                    <StackPanel>

                        <ContentControl Content="{Binding SelectedBook}"
                                        ContentTemplate="{StaticResource BookDetailTemplate}"/>

                        <TextBlock Text="Editor"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="5,15,5,5"/>

                        <TextBlock Text="Title" Margin="5,5,5,0"/>
                        <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <TextBlock Text="Author" Margin="5,5,5,0"/>
                        <TextBox Text="{Binding NewAuthor, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <TextBlock Text="Publication Year" Margin="5,5,5,0"/>
                        <TextBox Text="{Binding NewPublicationYear, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <WrapPanel Margin="5">
                            <Button Content="Add"
                                    Width="80"
                                    Margin="3"
                                    Command="{Binding AddBookCommand}"/>

                            <Button Content="Update"
                                    Width="80"
                                    Margin="3"
                                    Command="{Binding UpdateBookCommand}"/>

                            <Button Content="Delete"
                                    Width="80"
                                    Margin="3"
                                    Command="{Binding DeleteBookCommand}"/>

                            <Button Content="Clear"
                                    Width="80"
                                    Margin="3"
                                    Command="{Binding ClearEditorCommand}"/>
                        </WrapPanel>

                        <TextBlock Text="Reader for borrowing"
                                   Margin="5,15,5,0"/>

                        <ComboBox ItemsSource="{Binding Readers}"
                                  SelectedItem="{Binding SelectedReader, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Margin="5"/>

                        <WrapPanel Margin="5">
                            <Button Content="Borrow"
                                    Width="100"
                                    Margin="3"
                                    Command="{Binding BorrowBookCommand}"/>

                            <Button Content="Return"
                                    Width="100"
                                    Margin="3"
                                    Command="{Binding ReturnBookCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <GroupBox Header="Events"
                  Grid.Row="2"
                  Margin="0,10,0,0">

            <ListBox ItemsSource="{Binding Events}"
                     ItemTemplate="{StaticResource EventTemplate}"/>
        </GroupBox>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>